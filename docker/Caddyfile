{
    auto_https off
}

:80 {
    route {
        encode zstd gzip

        header {
            Referrer-Policy strict-origin-when-cross-origin
            X-Content-Type-Options nosniff
            X-Frame-Options SAMEORIGIN
        }

        handle /api/* {
            reverse_proxy api:8000
        }

        handle /health {
            reverse_proxy api:8000
        }

        handle /artifacts/* {
            reverse_proxy api:8000
        }

        handle /pay/* {
            reverse_proxy api:8000
        }

        handle /vnc.html* {
            reverse_proxy hold_worker:6080
        }

        handle /vnc_lite.html* {
            reverse_proxy hold_worker:6080
        }

        # WebSocket endpoint for noVNC. Caddy v2 proxies WebSocket upgrades
        # natively — do NOT set Connection/Upgrade via header_up; they are
        # hop-by-hop headers and manual overrides can break the upgrade
        # handshake (THR-125).
        handle /websockify* {
            reverse_proxy hold_worker:6080
        }

        handle /app/* {
            reverse_proxy hold_worker:6080
        }

        handle /core/* {
            reverse_proxy hold_worker:6080
        }

        handle /vendor/* {
            reverse_proxy hold_worker:6080
        }

        # noVNC 1.4 fetches these relative to /vnc.html; without these
        # handles they fall through to the SPA fallback and return
        # index.html, producing JSON-parse console errors (THR-125).
        handle /defaults.json {
            reverse_proxy hold_worker:6080
        }

        handle /mandatory.json {
            reverse_proxy hold_worker:6080
        }

        handle /package.json {
            reverse_proxy hold_worker:6080
        }

        handle {
            root * /srv
            try_files {path} /index.html
            file_server
        }
    }
}
