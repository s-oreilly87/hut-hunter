APP_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://huthunter:huthunter@localhost:5433/huthunter
REDIS_URL=redis://localhost:6379
SECRET_KEY=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-generated-fernet-key
ENVIRONMENT=development

BROWSER_HEADLESS_DETECT=true
BROWSER_DISPLAY=
VNC_URL=http://localhost:6080

GOTIFY_URL=
GOTIFY_TOKEN=

# Temporary global fallback for DOC login.
# Planned future direction: store per-user DOC credentials in the database
# after user accounts and credential-storage hardening are in place.
DOC_EMAIL=
DOC_PASSWORD=

# Compose/dev database defaults.
POSTGRES_USER=huthunter
POSTGRES_PASSWORD=huthunter
POSTGRES_DB=huthunter
