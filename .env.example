APP_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://huthunter:huthunter@localhost:5433/huthunter
REDIS_URL=redis://localhost:6379
SECRET_KEY=replace-with-a-long-random-secret
ENVIRONMENT=development

# Keep ENCRYPTION_KEY secret so the API / workers can decrypt those records.
ENCRYPTION_KEY=replace-with-a-generated-fernet-key

BROWSER_HEADLESS_DETECT=true
BROWSER_DISPLAY=
VNC_PORT=6080
# Optional absolute override for the public noVNC base URL.
# In production behind the bundled reverse proxy, this can match APP_URL.
# When ENVIRONMENT=production, APP_URL is used automatically if VNC_URL is unset.
# VNC_URL=https://hut-hunter.seanoreilly.dev

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@hut-hunter.local
SMTP_FROM_NAME="Hut Hunter"
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=false

# Booking credentials and notification delivery targets now live per user in the database.

# Compose/dev database defaults.
POSTGRES_USER=huthunter
POSTGRES_PASSWORD=huthunter
POSTGRES_DB=huthunter

# Production notes:
# - Set ENVIRONMENT=production so auth cookies become Secure.
# - Set APP_URL to the public origin.
# - VNC_URL is optional in production; when unset, APP_URL (or the incoming
#   request host) is used so noVNC is reached on the same origin as /pay.
# - Replace SMTP_* with a real mail provider; Mailpit is dev-only.

# Used by the future AdapterBuilder Agentic workflow !! Careful! Currently burns tokens for little useable output!
ANTHROPIC_API_KEY=
