APP_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://huthunter:huthunter@localhost:5433/huthunter
REDIS_URL=redis://localhost:6379
SECRET_KEY=replace-with-a-long-random-secret
ENVIRONMENT=development

# Keep ENCRYPTION_KEY secret so the API / workers can decrypt those records.
ENCRYPTION_KEY=replace-with-a-generated-fernet-key

BROWSER_HEADLESS_DETECT=true
BROWSER_DISPLAY=
VNC_URL=http://localhost:6080

GOTIFY_URL=
GOTIFY_TOKEN=

# Booking credentials now live per user in the database.

# Compose/dev database defaults.
POSTGRES_USER=huthunter
POSTGRES_PASSWORD=huthunter
POSTGRES_DB=huthunter

# Used by the future AdapterBuilder Agentic workflow !! Careful! Currently burns tokens for little useable output!
ANTHROPIC_API_KEY=
